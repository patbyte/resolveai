# The app uses a deterministic local provider when this key is omitted.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# The deterministic demo store is the default. Use postgres after migrating and
# seeding the local database.
TICKET_STORE=demo
DATABASE_URL=postgresql://resolveai:resolveai@localhost:5432/resolveai

# Reserved for the distributed rate-limit milestone.
REDIS_URL=redis://localhost:6379
